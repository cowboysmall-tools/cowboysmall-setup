#!/usr/bin/env bash


# store the location of the script
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"


# make Apps directory if it doesn't already exist



# download archive
curl -sL https://github.com/dylanaraps/neofetch/releases/latest -o /tmp/neofetch-latest.tar.gz


# extract to Apps directory
tar xzvf /tmp/neofetch-latest.tar.gz -C /tmp/


# install files
install -D /tmp/neofetch/neofetch -t $HOME/.local/bin



# update desktop files




# copy configs



# cleanup
rm -f /tmp/neofetch-latest.tar.gz
